rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, name, location, lands, landSize, primaryCrops, soilType, income, category, isAadharLinked
    //
    // Collection: users/{uid}/soilHealth
    // Fields: uid, nitrogen, phosphorus, potassium, ph, organicCarbon, lastUpdated
    //
    // Collection: market_products
    // Fields: sellerId, sellerName, commodity, quantity, unit, pricePerUnit, location, dateListed, status
    //
    // Collection: users/{uid}/chatHistory
    // Fields: uid, role, content, timestamp
    //
    // Collection: schemes
    // Fields: name, description, eligibilityCriteria, benefits, link, category
    //
    // Collection: diseases
    // Fields: diseaseName, cropAffected, symptoms, remedy, prevention, trending
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "s24_patil_prasad@mgmmumbai.ac.in" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name']) &&
             data.uid is string && data.name is string &&
             (!('income' in data) || data.income is number) &&
             (!('category' in data) || data.category in ['Small', 'Marginal', 'Large']);
    }

    function isValidSoilHealth(data) {
      return data.uid is string &&
             (!('nitrogen' in data) || data.nitrogen is number) &&
             (!('ph' in data) || data.ph is number);
    }

    function isValidMarketProduct(data) {
      return data.sellerId is string &&
             data.commodity is string &&
             data.quantity is number &&
             data.pricePerUnit is number &&
             data.status in ['available', 'sold'];
    }

    function isValidReminder(data) {
      return data.uid is string &&
             data.title is string &&
             data.title.size() > 0 &&
             data.title.size() < 100 &&
             data.activityType in ['fertilizer', 'watering', 'harvesting', 'pesticide', 'other'] &&
             data.dueDate is string &&
             data.isCompleted is bool;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;

      match /soilHealth/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) && isValidSoilHealth(request.resource.data);
      }

      match /chatHistory/{messageId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.uid == userId;
      }
    }

    match /market_products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid && isValidMarketProduct(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin()) && isValidMarketProduct(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
    }

    match /labour_listings/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.workerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.workerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.workerId == request.auth.uid || isAdmin());
    }

    match /schemes/{schemeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /diseases/{diseaseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /labTests/{testId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && 
                    request.resource.data.amount == 49 && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /reminders/{reminderId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidReminder(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin()) && isValidReminder(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }
  }
}
